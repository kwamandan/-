#!name=AdBlock Balanced 15-in-1
#!desc=Converted from flclash-adblock-balanced-15in1.yaml. Blocks common ad, privacy, tracker and app-ad rule lists with REJECT.
#!author=Codex
#!homepage=https://github.com/

[Rule]
# Loyalsoldier reject
RULE-SET,https://cdn.jsdelivr.net/gh/Loyalsoldier/clash-rules@release/reject.txt,REJECT

# Anti-AD, Surge/Loon compatible text list
RULE-SET,https://anti-ad.net/surge.txt,REJECT

# blackmatrix7 Advertising, Loon format
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Loon/Advertising/Advertising.list,REJECT

# ACL4SSR ad lists, Loon format
RULE-SET,https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Loon/BanAD.list,REJECT
RULE-SET,https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Loon/BanEasyList.list,REJECT
RULE-SET,https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Loon/BanEasyListChina.list,REJECT
RULE-SET,https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Loon/BanEasyPrivacy.list,REJECT
RULE-SET,https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Loon/BanProgramAD.list,REJECT

# MetaCubeX category ads classical list
RULE-SET,https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/meta/geo/geosite/classical/category-ads-all.list,REJECT

# The original Clash profile also included these providers, but they are not enabled here
# because Loon usually cannot consume Clash YAML provider files or Mihomo MRS files directly:
#
# earoftoast_AD:
# https://raw.githubusercontent.com/earoftoast/clash-rules/main/AD.yaml
#
# earoftoast_ProgramAD:
# https://raw.githubusercontent.com/earoftoast/clash-rules/main/ProgramAD.yaml
#
# awavenue_ads, Mihomo MRS:
# https://raw.githubusercontent.com/TG-Twilight/AWAvenue-Ads-Rule/main/Filters/AWAvenue-Ads-Rule-Clash.mrs
#
# hagezi_pro_plus, Mihomo MRS:
# https://cdn.jsdelivr.net/gh/MiHomoer/MiHomo-Hagezi@release/HageziProPlus.mrs
#
# oisd_big, Mihomo MRS:
# https://github.com/legiz-ru/mihomo-rule-sets/raw/main/oisd/big.mrs
#
# clashBlock_youtube:
# https://raw.githubusercontent.com/alfatihart/clashBlock/main/youtube_adblock.yaml
